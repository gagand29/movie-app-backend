# Ignore node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore environment variables
.env
.env.local
.env.development
.env.production
.env.test
.env*.local

# Ignore build files
/build
/dist

# Ignore database-related files (if using SQLite)
*.sqlite
*.sqlite-journal

# Ignore logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Ignore VSCode settings (if using VSCode)
.vscode/

# Ignore coverage reports (if using Jest or testing)
coverage/
*.lcov

# Ignore temporary files
.DS_Store
Thumbs.db

# Ignore process-related files
*.pid
*.seed
*.pid.lock

# Ignore Docker files (if using Docker)
.dockerignore

uploads/
